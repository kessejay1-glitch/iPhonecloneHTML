<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HTML5 iPhone</title>
    <style>
        :root { --ios-blur: blur(20px); --ios-bg: linear-gradient(180deg, #ff9a9e 0%, #fad0c4 99%, #fad0c4 100%); }
        body { background: #000; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; }
        
        /* The Hardware Frame */
        .iphone-frame { width: 320px; height: 650px; background: #1c1c1e; border: 12px solid #3a3a3c; border-radius: 50px; position: relative; overflow: hidden; box-shadow: 0 25px 50px rgba(0,0,0,0.5); }
        
        /* The Wallpaper */
        .screen { height: 100%; background: var(--ios-bg); display: flex; flex-direction: column; padding: 20px; box-sizing: border-box; }

        /* Status Bar */
        header { display: flex; justify-content: space-between; font-size: 12px; font-weight: 600; padding: 10px 15px; }

        /* App Grid */
        main { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-top: 30px; }
        figure { margin: 0; display: flex; flex-direction: column; align-items: center; }
        
        /* SVG App Icons */
        .icon { width: 55px; height: 55px; border-radius: 12px; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 10px rgba(0,0,0,0.1); margin-bottom: 5px; }
        figcaption { font-size: 11px; color: white; text-shadow: 0 1px 2px rgba(0,0,0,0.5); }

        /* The Dock (Glass Effect) */
        nav { background: rgba(255, 255, 255, 0.25); backdrop-filter: var(--ios-blur); -webkit-backdrop-filter: var(--ios-blur); border-radius: 25px; padding: 10px; margin-top: auto; display: flex; justify-content: space-around; }

        /* Home Bar */
        .home-bar { width: 120px; height: 5px; background: white; border-radius: 10px; margin: 15px auto 5px; opacity: 0.8; }
    </style>
</head>
<body>

<div class="iphone-frame">
    <div class="screen">
        <header>
            <time>9:41</time>
            <div>📶 WI <meter value="0.9" style="width:20px"></meter></div>
        </header>

        <main>
            <figure>
                <div class="icon" style="background: linear-gradient(#5cfd9f, #2bb75a);">
                    <svg viewBox="0 0 24 24" width="30" fill="white"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
                </div>
                <figcaption>Phone</figcaption>
            </figure>

            <figure>
                <div class="icon" style="background: #fff;">
                    <svg viewBox="0 0 24 24" width="30" fill="#007aff"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
                </div>
                <figcaption>Mail</figcaption>
            </figure>

            <figure>
                <div class="icon" style="background: linear-gradient(#54ccfc, #007aff);">
                    <svg viewBox="0 0 24 24" width="30" fill="white"><path d="M12 2L4.5 20.29l.71.71L12 18l6.79 3 .71-.71z"/></svg>
                </div>
                <figcaption>Safari</figcaption>
            </figure>

            <figure>
                <div class="icon" style="background: #000;">
                    <svg viewBox="0 0 24 24" width="30" fill="white"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"/></svg>
                </div>
                <figcaption>Music</figcaption>
            </figure>
        </main>

        <nav>
            <div class="icon" style="background: #2bb75a; width:45px; height:45px; border-radius:10px;">💬</div>
            <div class="icon" style="background: #ff9500; width:45px; height:45px; border-radius:10px;">🎨</div>
            <div class="icon" style="background: #5856d6; width:45px; height:45px; border-radius:10px;">📷</div>
            <div class="icon" style="background: #ff2d55; width:45px; height:45px; border-radius:10px;">❤️</div>
        </nav>

        <div class="home-bar"></div>
    </div>
</div>

</body>
</html>

