<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Open Source HTML5 iPhone</title>
    <style>
        :root { --ios-blue: #007aff; --ios-bg: #f2f2f7; }
        body { background: #1a1a1a; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; font-family: -apple-system, sans-serif; }
        
        .iphone { width: 350px; height: 700px; background: #000; border: 12px solid #333; border-radius: 50px; position: relative; overflow: hidden; display: flex; flex-direction: column; }
        
        /* Screen Styles */
        #screen { flex: 1; background: white; display: flex; flex-direction: column; overflow: hidden; }
        
        /* App Content Area */
        main { flex: 1; overflow-y: auto; position: relative; }
        .app-page { display: none; height: 100%; width: 100%; flex-direction: column; padding: 20px; box-sizing: border-box; }
        .active { display: flex; }

        /* Navigation Bar */
        nav { background: rgba(240, 240, 240, 0.9); backdrop-filter: blur(10px); display: flex; justify-content: space-around; padding: 15px 10px; border-top: 1px solid #ccc; }
        .nav-btn { background: none; border: none; font-size: 24px; cursor: pointer; transition: transform 0.2s; }
        .nav-btn:active { transform: scale(0.8); }

        /* Camera Viewfinder */
        video { width: 100%; height: 80%; background: #000; border-radius: 20px; object-fit: cover; }
    </style>
</head>
<body>

<div class="iphone">
    <div id="screen">
        <header style="padding: 10px 20px; display: flex; justify-content: space-between; font-size: 12px; font-weight: bold;">
            <span id="clock">9:41</span>
            <span>📶 🔋</span>
        </header>

        <main id="app-container">
            <section id="home" class="app-page active">
                <h1 style="margin-top: 40px;">Welcome</h1>
                <p>Tap a system icon below to launch an app.</p>
                <div style="border: 2px dashed #ccc; padding: 20px; margin-top: 20px; color: #666; font-size: 12px;">
                    [Placeholder: Add Widgets Here]
                </div>
            </section>

            <section id="camera" class="app-page">
                <h3>Camera</h3>
                <video id="viewfinder" autoplay playsinline></video>
                <button onclick="takePhoto()" style="margin-top: 10px; padding: 10px; border-radius: 50%; width: 50px; height: 50px; border: 4px solid #ccc; background: white; align-self: center;"></button>
            </section>

            <section id="safari" class="app-page" style="padding: 0;">
                <input type="text" id="url-bar" placeholder="Enter URL..." style="width: 100%; padding: 10px; border: none; background: #eee;">
                <iframe id="browser-frame" src="https://www.wikipedia.org" style="flex: 1; border: none;"></iframe>
            </section>

            </main>

        <nav>
            <button class="nav-btn" title="Home" onclick="showApp('home')">🏠</button>
            <button class="nav-btn" title="Camera" onclick="startCamera()">📷</button>
            <button class="nav-btn" title="Browser" onclick="showApp('safari')">🌐</button>
            <button class="nav-btn" style="opacity: 0.3;" title="Add App">+</button>
        </nav>
    </div>
</div>

<script>
    // System Clock
    setInterval(() => {
        document.getElementById('clock').innerText = new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
    }, 1000);

    // App Navigation Logic
    function showApp(appId) {
        document.querySelectorAll('.app-page').forEach(page => page.classList.remove('active'));
        document.getElementById(appId).classList.add('active');
        
        // Stop camera if leaving camera app
        if (appId !== 'camera' && window.localStream) {
            window.localStream.getTracks().forEach(track => track.stop());
        }
    }

    // Camera Logic (Working HTML5 Media API)
    async function startCamera() {
        showApp('camera');
        try {
            const stream = await navigator.mediaDevices.getUserMedia({ video: true });
            document.getElementById('viewfinder').srcObject = stream;
            window.localStream = stream;
        } catch (err) {
            alert("Camera access denied or not available.");
        }
    }

    function takePhoto() {
        alert("Flash! Photo 'captured' (Add LocalStorage logic here to save)");
    }

    // Browser logic
    document.getElementById('url-bar').addEventListener('keypress', function (e) {
        if (e.key === 'Enter') {
            let url = this.value;
            if (!url.startsWith('http')) url = 'https://' + url;
            document.getElementById('browser-frame').src = url;
        }
    });
</script>

</body>
</html>
